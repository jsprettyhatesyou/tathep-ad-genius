# Supabase — server-only secrets (no VITE_ prefix → never shipped to browser)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — น้องตาเทพ brain. Get from platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-...

# Apify — Google Maps Scraper. Used to fetch verified central phone numbers for
# leads from Google Maps (AI no longer guesses phone numbers).
# Get from: console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=

# Resend — sends quotation / invoice emails from the deal Documents tab.
# Sign up free at resend.com → API Keys. To send to real inboxes you must verify
# a sending domain; RESEND_FROM must use that domain. Without a verified domain,
# "onboarding@resend.dev" only delivers to your own Resend account email.
RESEND_API_KEY=re_...
RESEND_FROM=Tathep <docs@yourdomain.com>

# Issuer details printed on quotations / invoices (optional — falls back to the
# constants in src/lib/issuer.ts when unset).
ISSUER_NAME=Tathep Technology Co., Ltd.
ISSUER_TAX_ID=0000000000000
ISSUER_ADDRESS=กรุงเทพมหานคร ประเทศไทย
ISSUER_PHONE=
ISSUER_EMAIL=hello@tathep.com
ISSUER_WEBSITE=www.tathep.com
ISSUER_BANK_NAME=
ISSUER_BANK_ACCOUNT_NAME=Tathep Technology Co., Ltd.
ISSUER_BANK_ACCOUNT_NO=
ISSUER_LOGO_URL=
