# Supabase — server-only secrets (no VITE_ prefix → never shipped to browser)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — น้องตาเทพ brain. Get from platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-...

# Apify — Google Maps Scraper. Used to fetch verified central phone numbers for
# leads from Google Maps (AI no longer guesses phone numbers).
# Get from: console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=
